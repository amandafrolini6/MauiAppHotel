<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Login"
             Title="Login">

	<VerticalStackLayout Padding="10" Margin="10">
		<Label Text="Faça seu login!" HorizontalTextAlignment="Center" Margin="40" FontSize="30" FontFamily="BangersRegular" TextColor="MediumPurple"/>

        <Border Margin="10" BackgroundColor="{StaticResource Secondary}">
			<VerticalStackLayout Spacing="10">
				<Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="10">
					
					<Label Grid.Row="0" Text="E-mail:" />
					<Entry x:Name="txt_email" Grid.Row="1" Keyboard="Email"  Placeholder="seu-email@example.com"/>

					<Label Grid.Row="2" Text="Senha: "/>
					<Entry x:Name="txt_senha" Grid.Row="3" IsPassword="True" Placeholder="sua senha"/>
					
				</Grid>
				
				<Button Text="Entrar" Clicked="Button_Clicked_Entrar" HorizontalOptions="Center"/>

				<Button Text="Cadastrar" Clicked="Button_Clicked_Cadastrar" HorizontalOptions="Center"/>
			</VerticalStackLayout>
		</Border>
	</VerticalStackLayout>
	
</ContentPage>